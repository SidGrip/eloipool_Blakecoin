[Unit]
Description=BlakeStream merged-mine proxy
After=network-online.target blakecoin-pool.service
Wants=network-online.target
Requires=blakecoin-pool.service

[Service]
Type=simple
User=@@POOL_USER@@
Group=@@POOL_GROUP@@
WorkingDirectory=@@INSTALL_ROOT@@/eloipool
EnvironmentFile=-@@INSTALL_ROOT@@/config/proxy.env
Environment=PYTHONPATH=@@INSTALL_ROOT@@/config:@@INSTALL_ROOT@@/eloipool/vendor:@@INSTALL_ROOT@@/eloipool:@@INSTALL_ROOT@@
Environment=PYTHONUNBUFFERED=1
ExecStart=/bin/bash -lc 'exec @@INSTALL_ROOT@@/venv/bin/python -u @@INSTALL_ROOT@@/eloipool/merged-mine-proxy.py3 ${PROXY_ARGS}'
StandardInput=null
StandardOutput=append:@@LOG_ROOT@@/merged-mine-proxy.stdout
StandardError=append:@@LOG_ROOT@@/merged-mine-proxy.log
Restart=always
RestartSec=5

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
